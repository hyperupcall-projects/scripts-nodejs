{
	"include": [
		"config-eslint.js",
		"config-prettier.js",
		"scripts-nodejs.js"
	],
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"target": "es2015",
		"moduleResolution": "node16",
		"module": "node16",
		"lib": [
			"es2019"
		],
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "./output"
	}
}